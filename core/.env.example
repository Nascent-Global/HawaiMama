USE_S3=false

# Local object storage mode
LOCAL_OBJECT_STORAGE_ROOT=./wwwroots
LOCAL_OBJECT_STORAGE_URL_PREFIX=/wwwroots

# S3 object storage mode
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
S3_PREFIX=traffic-monitoring

# Optional database override
TRAFFIC_MONITORING_DATABASE_URL=postgresql://hawaimama:hawaimama_dev@localhost:5433/hawaimama

# Admin panel auth
ADMIN_ALLOWED_ORIGINS=http://localhost:3000
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123
SUPERADMIN_FULL_NAME=System Superadmin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FULL_NAME=Default Office Admin
